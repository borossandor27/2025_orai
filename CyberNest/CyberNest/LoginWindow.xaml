<Window x:Class="CyberNest.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bejelentkezés" Height="200" Width="300" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="Elérhetőség:"/>
        <TextBox x:Name="EmailInput" Margin="0,5,0,10" Text="admin@local"/>

        <TextBlock Text="Jelszó:"/>
        <PasswordBox x:Name="PasswordInput" Margin="0,5,0,15"/>

        <Button Content="Bejelentkezés" Click="LoginButton_Click" Height="30" Background="LightBlue"/>
    </StackPanel>
</Window>
